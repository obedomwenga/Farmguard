{
  "entities": {
    "User": {
      "title": "User",
      "description": "A farmer using the platform.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "createdAt"]
    },
    "FarmProfile": {
      "title": "Farm Profile",
      "description": "A farm belonging to a user.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "crop": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "crop", "latitude", "longitude", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile information including phone number."
    },
    "farms/{farmId}": {
      "schema": { "$ref": "#/entities/FarmProfile" },
      "description": "Farm locations and crops associated with a user."
    }
  }
}
